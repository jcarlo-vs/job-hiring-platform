# ----------------------------------------------------------------------------
# Supabase (Phase 0) - client-safe values, exposed to the browser
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (sb_publishable_...) or legacy anon JWT. Safe for the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-only secret key (sb_secret_... or legacy service_role JWT). NEVER expose
# with a NEXT_PUBLIC_ prefix. Used from Phase 3 for signed upload/download URLs.
# Copy from: Supabase Dashboard -> Project Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Keep-alive (Phase 0) - gates the /api/health endpoint
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------------------------
CRON_SECRET=

# ----------------------------------------------------------------------------
# Anthropic (Phase 4) - AI resume screening
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------------
# Inngest (Phase 4) - background jobs.
# Local dev: set INNGEST_DEV=1 and run the Inngest dev server; keys not needed.
# Production: the Inngest Vercel integration injects EVENT_KEY + SIGNING_KEY.
# ----------------------------------------------------------------------------
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----------------------------------------------------------------------------
# Resend (Phase 6) - transactional email
# Without RESEND_API_KEY the email steps no-op (logged), so the app still runs.
# RESEND_FROM must be a verified sender; the shared onboarding@resend.dev only
# delivers to your own Resend account email until you verify a domain.
# ----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM="TalentScreen <onboarding@resend.dev>"

# Public base URL used for links in emails (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://job-hiring-platform-eight.vercel.app
